{
  "name": "@nezha-dash/sdk",
  "version": "1.0.0",
  "description": "Official JavaScript SDK for NezhaDash Pro API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "build:cjs": "tsc",
    "build:esm": "tsc -p tsconfig.esm.json",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "keywords": [
    "nezha",
    "nezha-dash",
    "monitoring",
    "dashboard",
    "api-client",
    "sdk"
  ],
  "author": "NezhaDash Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nezha-dash/nezha-dash-pro",
    "directory": "sdk/javascript"
  },
  "bugs": {
    "url": "https://github.com/nezha-dash/nezha-dash-pro/issues"
  },
  "homepage": "https://github.com/nezha-dash/nezha-dash-pro/tree/main/sdk/javascript#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "dependencies": {}
}
