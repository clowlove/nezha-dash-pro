# =============================================================================
# NezhaDash Pro — Environment Configuration
# =============================================================================

# --- Core Data Source ---
# Nezha Monitoring Panel
NezhaBaseUrl=http://your-nezha-server:8008
NezhaAuth=your-nezha-api-token

# Komari Panel (alternative data source)
NEXT_PUBLIC_Komari=false
KomariBaseUrl=https://your-komari-instance.com

# MyNodeQuery Panel (alternative data source)
NEXT_PUBLIC_MyNodeQuery=false
MyNodeQueryBaseUrl=https://your-mynodequery-instance.com

# Uptime Kuma (alternative data source)
NEXT_PUBLIC_UptimeKuma=false
UptimeKumaBaseUrl=https://your-uptimekuma-instance.com
UptimeKumaApiKey=your-uptimekuma-api-key

# --- Display Settings ---
DefaultLocale=zh
ForceShowAllServers=false
NEXT_PUBLIC_NezhaFetchInterval=5000
NEXT_PUBLIC_ShowFlag=true
NEXT_PUBLIC_DisableCartoon=false
NEXT_PUBLIC_ShowTag=true
NEXT_PUBLIC_ShowNetTransfer=false
NEXT_PUBLIC_ForceUseSvgFlag=false
NEXT_PUBLIC_FixedTopServerName=false
NEXT_PUBLIC_CustomLogo=
NEXT_PUBLIC_CustomTitle=NezhaDash Pro
NEXT_PUBLIC_CustomDescription=AI-Powered VPS Monitoring Dashboard
NEXT_PUBLIC_Links='[{"link":"https://github.com/clowlove/nezha-dash-pro","name":"GitHub"}]'
NEXT_PUBLIC_DisableIndex=false
NEXT_PUBLIC_ShowTagCount=false
NEXT_PUBLIC_ShowIpInfo=false
NEXT_PUBLIC_ShowServerDetailSummary=true

# --- Authentication ---
SITE_PASSWORD=your-secure-password
AUTH_SECRET=your-auth-secret-min-32-chars

# --- 2FA (Two-Factor Authentication) ---
TWO_FACTOR_ENCRYPTION_KEY=your-32-char-encryption-key
TWO_FACTOR_ISSUER=NezhaDashPro

# --- AI Alert Diagnosis ---
AI_DIAGNOSIS_API_KEY=your-openai-api-key
AI_DIAGNOSIS_MODEL=gpt-4o
AI_DIAGNOSIS_BASE_URL=https://api.openai.com/v1

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# --- Discord Notifications ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# --- Historical Data Storage ---
STORAGE_PATH=./data/nezha.db
METRICS_RETENTION_DAYS=90

# --- SaaS Configuration ---
SAAS_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
